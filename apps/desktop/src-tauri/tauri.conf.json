{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Transcript Extractor",
  "version": "0.1.0",
  "identifier": "com.videotranscriptextractor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Video Transcript Extractor",
        "width": 1100,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/**/*",
      "models/**/*"
    ]
  },
  "plugins": {}
}
